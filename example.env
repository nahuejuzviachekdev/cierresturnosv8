#SQL Server Proveedor
SQLSERVER_HOST_1=192.168.1.100
SQLSERVER_PORT_1=1433
SQLSERVER_USER_1=usuario_sql
SQLSERVER_PASSWORD_1=contrasena_sql
SQLSERVER_ENCRYPT_1=no
SQLSERVER_DB=NombreBaseSqlServer
IDEstacion=1

# PostgreSQL Destino (tal como se ve DESDE el servidor destino -- normalmente 127.0.0.1 --
# ya que la conexion real llega por el tunel SSH, ver seccion TUNEL mas abajo)
HOST=127.0.0.1
DATABASE=nombre_base_postgres
USERNAME=usuario_postgres
PASSWORD=contrasena_postgres
PORT_1=5432
SCHEMA=nombre_estacion

# Tunel SSH hacia el Postgres destino (2 saltos: VPS -> servidor con Postgres)
TUNNEL_VPS_HOST=vps.ejemplo.com
TUNNEL_VPS_PORT=22
TUNNEL_VPS_USER=usuario_vps
TUNNEL_LOCAL_USER=usuario_servidor_destino
TUNNEL_REMOTE_PORT=2222
TUNNEL_KEY_FILE=.\llave_remota
TUNNEL_MAX_INTENTOS=3
TUNNEL_ESPERA_REINTENTO=15
TUNNEL_TIMEOUT=15

# Python Portable (ruta al interprete python.exe, solo se usa si no hay Python en el PATH del sistema)
PYTHON_PATH=C:\ruta\a\python_portable\python.exe
